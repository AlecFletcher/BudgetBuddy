<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Budget_Buddy.AddCategory"
             Title="Add Category"
             xmlns:models ="clr-namespace:Budget_Buddy.Models">
    <VerticalStackLayout>
        <CollectionView x:Name="categoriesCollectionView" x:DataType="models:Category">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border>
                        <Grid ColumnDefinitions="*,60" RowDefinitions="80">
                            <Entry Text="{Binding Name}" HorizontalTextAlignment="Center" FontSize="28" VerticalOptions="Center"/>
                            <ImageButton Source="trashcan.png" MaximumHeightRequest="50" Clicked="Trashcan_Clicked" Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center"/>
                        </Grid>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Grid ColumnDefinitions="*,80,10">
            <ImageButton Source="plus_symbol.png" Grid.Column="1" Clicked="Plus_Button_Clicked"></ImageButton>
        </Grid>

    </VerticalStackLayout>
</ContentPage>